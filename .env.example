# ── mnemo configuration ─────────────────────────────────────────────────────
# Copy to `.env`. This template is the VERIFIED, 100%-local, free setup:
#   LLM: Ollama (on your machine)   ·   Embeddings: fastembed (on your machine)
# No API keys, no cloud, no external dependency.

# ── Reasoning LLM: Ollama (local) ──────────────────────────────────────────
# Install:  brew install ollama  &&  ollama serve
# Model:    ollama pull qwen2.5:7b   (qwen2.5 is strong at the structured/JSON
#           output Cognee needs; llama3.1:8b struggles with it.)
LLM_PROVIDER="ollama"
LLM_MODEL="qwen2.5:7b"
LLM_ENDPOINT="http://localhost:11434/v1"
LLM_API_KEY="ollama"                 # dummy value — Ollama needs no real key

# ── Embeddings: fastembed (local, on-device) ───────────────────────────────
# EMBEDDING_DIMENSIONS is REQUIRED by Cognee when you set a custom embedder.
# all-MiniLM-L6-v2 = 384. Pick your embedder BEFORE the first `mnemo ingest`;
# switching later changes the vector size and needs `mnemo forget --all`.
EMBEDDING_PROVIDER="fastembed"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
EMBEDDING_DIMENSIONS="384"

# ── Local databases / posture ──────────────────────────────────────────────
# NOTE: Do NOT set DATA_ROOT_DIRECTORY / SYSTEM_ROOT_DIRECTORY here. Cognee
# re-reads .env with override=True at import and requires ABSOLUTE paths;
# config.py sets them to absolute paths under ./.mnemo for you.
ENABLE_BACKEND_ACCESS_CONTROL="false"
TELEMETRY_DISABLED="1"

# ── Alternative: Anthropic Claude (paid) ────────────────────────────────────
# Swap the LLM block above for:
#   LLM_PROVIDER="anthropic"
#   LLM_MODEL="claude-opus-4-8"
#   LLM_API_KEY="sk-ant-..."
# (delete LLM_ENDPOINT). Keep the fastembed block as-is.
